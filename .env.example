# Leave this blank when using `gcloud auth application-default login`.
# Only set it to a service-account JSON key, not an OAuth client_secret JSON.
GOOGLE_APPLICATION_CREDENTIALS=

# Existing Drive folder ID, or omit to create SocialArchive in the authenticated account's My Drive.
SOCIAL_ARCHIVE_ROOT_ID=

# One or more source URLs, comma-separated.
INSTAGRAM_SOURCE_URLS=https://www.instagram.com/your_username/
YOUTUBE_SOURCE_URLS=https://www.youtube.com/@your_channel/videos,https://www.youtube.com/@your_channel/shorts

# Optional Netscape cookies file for private/authenticated content.
INSTAGRAM_COOKIES_FILE=
YOUTUBE_COOKIES_FILE=

# Optional overrides.
YTDLP_PATH=yt-dlp
SOCIAL_ARCHIVE_TMP_DIR=
