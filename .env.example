# Personal Google account OAuth:
#   Leave this blank. Run `gcloud auth application-default login --client-id-file=...`
#   and choose the Google account whose Drive quota should store the archive.
#
# Service account mode only:
#   Set this to a downloaded service-account JSON key, then share the Drive folder
#   with that service account's client_email and set SOCIAL_ARCHIVE_ROOT_ID.
#
# Never set this to an OAuth `client_secret_...apps.googleusercontent.com.json` file.
GOOGLE_APPLICATION_CREDENTIALS=

# Existing Drive folder ID, or omit to create SocialArchive in the authenticated account's My Drive.
SOCIAL_ARCHIVE_ROOT_ID=

# One or more source URLs, comma-separated.
INSTAGRAM_SOURCE_URLS=https://www.instagram.com/your_username/
YOUTUBE_SOURCE_URLS=https://www.youtube.com/@your_channel/videos,https://www.youtube.com/@your_channel/shorts

# Optional Netscape cookies file for private/authenticated content.
INSTAGRAM_COOKIES_FILE=
YOUTUBE_COOKIES_FILE=

# Optional overrides.
YTDLP_PATH=yt-dlp
SOCIAL_ARCHIVE_TMP_DIR=
